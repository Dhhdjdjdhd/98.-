# 서버 포트 (Render는 자동 주입)
PORT=3000

# --- 로컬 개발(JSON 저장소) ---
# 아래 MONGODB_URI를 비워두면 로컬 JSON 파일(data/)로 동작
DATA_DIR=./data

# --- 배포(MongoDB 저장소) ---
# 이 값이 설정되면 MongoDB Atlas를 사용 (Render 환경변수에 등록)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=momcare

# 빈 DB 자동 시드 끄기 (기본: 켜짐). 끄려면 false
# AUTO_SEED=false

# --- 인증(JWT) ---
# 토큰 서명 비밀키 (배포 시 반드시 안전한 값으로 설정 / Render는 자동 생성)
JWT_SECRET=momcare-dev-secret-change-me
